from serdde.convert import decode_i32
from serdde.convert import decode_i8
from serdde.convert import decode_str
from serdde.convert import encode_i32
from serdde.convert import encode_str
from serdde.convert import from_value
from serdde.convert import to_value
from serdde.error import ErrorKind
from serdde.error import SerddeError
from serdde.error import type_error
from serdde.json import dumps_value
from serdde.json import loads
from serdde.protocol import DecodeTarget
from serdde.protocol import deserialize_as
from serdde.protocol import reader_error
from serdde.protocol import serialize_to
from serdde.protocol import write_ok
from serdde.value import Value
from serdde.value import ValueKind
from serdde.value import empty_object_value


class CodecProbe:
    value: i32

    def serdde_serialize[Writer](
        self: &const[Self],
        output: &Writer,
    ) -> Result[bool, SerddeError]:
        started = write_ok(output, output.begin_object(1))
        if not started.ok:
            return started
        field = write_ok(output, output.write_field("value"))
        if not field.ok:
            return field
        encoded = serialize_to(self.value, output)
        if not encoded.ok:
            return Err(encoded.err.at_field("value"))
        return write_ok(output, output.end_object())

    def serdde_deserialize[Reader](
        input: &const[Reader],
    ) -> Result[CodecProbe, SerddeError]:
        if not input.is_object():
            return Err(reader_error(input, "expected object"))
        if not input.has_field("value"):
            return Err(SerddeError(kind=ErrorKind.MissingField, message="missing value"))
        decoded = deserialize_as(input.field("value"), DecodeTarget[i32]())
        if not decoded.ok:
            return Err(decoded.err.at_field("value"))
        return Ok(CodecProbe(decoded.value))


def expect_roundtrip(source: str) -> i32:
    parsed = loads(source)
    match parsed:
        case Err(_):
            return 1
        case Ok(value):
            encoded = dumps_value(value)
            match encoded:
                case Err(_):
                    return 2
                case Ok(text):
                    reparsed = loads(text)
                    match reparsed:
                        case Err(_):
                            return 3
                        case Ok(_):
                            return 0


def main() -> i32:
    if expect_roundtrip("null") != 0:
        return 1
    if expect_roundtrip("{\"name\":\"Ada\",\"active\":true,\"values\":[1,-2,3.5]}") != 0:
        return 2
    unicode = loads("\"\\u0041\\ud83d\\ude00\"")
    match unicode:
        case Err(_):
            return 3
        case Ok(value):
            if value.kind != ValueKind.String:
                return 4
            if len(value.string_value) != 5:
                return 5
    malformed = loads("{\"a\":1,}")
    match malformed:
        case Ok(_):
            return 6
        case Err(error):
            if error.line != 1:
                return 7
    encoded_number = encode_i32(42)
    if encoded_number.kind != ValueKind.I64 or encoded_number.i64_value != 42:
        return 8
    overflow = decode_i8(encode_i32(1000))
    match overflow:
        case Ok(_):
            return 9
        case Err(error):
            if error.kind != ErrorKind.Type:
                return 10
    decoded_text = decode_str(encode_str("dudu"))
    match decoded_text:
        case Err(_):
            return 11
        case Ok(text):
            if text != "dudu":
                return 12
    encoded_probe = to_value(CodecProbe(42))
    match encoded_probe:
        case Err(_):
            return 13
        case Ok(probe_value):
            probe = from_value[CodecProbe](probe_value)
            match probe:
                case Err(_):
                    return 14
                case Ok(value):
                    if value.value != 42:
                        return 15
    return 0


@test
def public_smoke_test():
    encoded = encode_i32(42)
    assert encoded.kind == ValueKind.I64
    assert encoded.i64_value == 42
    parsed = loads("{\"ready\":true}")
    assert parsed.ok
    assert parsed.value.field("ready").bool_value
