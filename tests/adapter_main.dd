from cpp import string
from cpp import utility
from serdde.convert import from_value
from serdde.convert import from_value_with
from serdde.convert import to_value
from serdde.convert import to_value_with
from serdde.error import SerddeError
from serdde.json import dumps
from serdde.json import loads
from serdde.macros import Serde
from serdde.protocol import deserialize_from
from serdde.protocol import reader_error
from serdde.protocol import serialize_to
from serdde.protocol import write_ok
from serdde.value import Value


class PairSerde:
    def serialize[Writer](
        value: &const[std.pair[std.string, i32]],
        output: &Writer,
    ) -> Result[bool, SerddeError]:
        started = write_ok(output, output.begin_object(2))
        if not started.ok:
            return started
        name_field = write_ok(output, output.write_field("name"))
        if not name_field.ok:
            return name_field
        name = serialize_to(value.first, output)
        if not name.ok:
            return Err(name.err.at_field("name"))
        score_field = write_ok(output, output.write_field("score"))
        if not score_field.ok:
            return score_field
        score = serialize_to(value.second, output)
        if not score.ok:
            return Err(score.err.at_field("score"))
        return write_ok(output, output.end_object())

    def deserialize[Reader](
        input: &const[Reader],
    ) -> Result[std.pair[std.string, i32], SerddeError]:
        if not input.is_object():
            return Err(reader_error(input, "expected pair object"))
        if not input.has_field("name"):
            return Err(reader_error(input, "missing pair name").at_field("name"))
        if not input.has_field("score"):
            return Err(reader_error(input, "missing pair score").at_field("score"))
        name = deserialize_from[str, Reader](input.field("name"))
        if not name.ok:
            return Err(name.err.at_field("name"))
        score = deserialize_from[i32, Reader](input.field("score"))
        if not score.ok:
            return Err(score.err.at_field("score"))
        return Ok(std.make_pair(std.string(name.value), score.value))


@derive(Serde)
class NativeEnvelope:
    id: u64

    @Serde(adapter="PairSerde")
    entry: std.pair[std.string, i32]


@derive(Serde)
enum NativeEvent:
    Pair:
        @Serde(adapter="PairSerde")
        entry: std.pair[std.string, i32]


def main() -> i32:
    pair: std.pair[std.string, i32] = std.make_pair(std.string("Ada"), 42)
    direct = to_value_with[std.pair[std.string, i32], PairSerde](pair)
    match direct:
        case Err(_):
            return 1
        case Ok(value):
            restored = from_value_with[std.pair[std.string, i32], PairSerde](value)
            match restored:
                case Err(_):
                    return 2
                case Ok(ready):
                    if ready.first != "Ada" or ready.second != 42:
                        return 3

    envelope = NativeEnvelope(id=7, entry=pair)
    encoded = to_value(envelope)
    match encoded:
        case Err(_):
            return 4
        case Ok(value):
            decoded = from_value[NativeEnvelope](value)
            match decoded:
                case Err(_):
                    return 5
                case Ok(ready):
                    if ready.entry.first != "Ada" or ready.entry.second != 42:
                        return 6

    event = NativeEvent.Pair(entry=pair)
    encoded_event = to_value(event)
    match encoded_event:
        case Err(_):
            return 7
        case Ok(value):
            decoded_event = from_value[NativeEvent](value)
            match decoded_event:
                case Err(_):
                    return 8
                case Ok(ready):
                    match ready:
                        case NativeEvent.Pair(entry):
                            if entry.first != "Ada" or entry.second != 42:
                                return 9

    json = dumps(envelope)
    if not json.ok or json.value != "{\"id\":7,\"entry\":{\"name\":\"Ada\",\"score\":42}}":
        return 10
    json_envelope = loads[NativeEnvelope](json.value)
    if not json_envelope.ok:
        return 11
    if json_envelope.value.entry.first != "Ada" or json_envelope.value.entry.second != 42:
        return 12

    event_json = dumps(event)
    if not event_json.ok or event_json.value != "{\"Pair\":{\"entry\":{\"name\":\"Ada\",\"score\":42}}}":
        return 13
    json_event = loads[NativeEvent](event_json.value)
    if not json_event.ok:
        return 14
    match json_event.value:
        case NativeEvent.Pair(entry):
            if entry.first != "Ada" or entry.second != 42:
                return 15
    return 0
